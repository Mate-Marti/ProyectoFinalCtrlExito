<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/24.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="co.edu.uniquindio.poo.proyectofinalctrlexito.viewController.UsuarioMenuViewController">
    <children>
        <Label fx:id="lblTituloUsuarioMenu" layoutX="110.0" layoutY="39.0" prefHeight="58.0" prefWidth="379.0" text="MENU DEL USUARIO">
         <font>
            <Font size="40.0" />
         </font></Label>
        <Label fx:id="lblInfo" layoutX="197.0" layoutY="105.0" text="Seleccione la accion que desea realizar">
        </Label>
        <Button fx:id="btnComprarEntrada" layoutX="424.0" layoutY="174.0" mnemonicParsing="false" onAction="#abrirCompra" text="Comprar Entrada" />
        <Button fx:id="btnInfoEvento" layoutX="221.0" layoutY="174.0" mnemonicParsing="false" onAction="#abrirEvento" text="Informacion de Eventos" />
        <Button fx:id="btnVolver" layoutX="453.0" layoutY="315.0" mnemonicParsing="false" onAction="#volver" text="Volver" />
      <Button fx:id="btnGestionPerfil" layoutX="56.0" layoutY="174.0" mnemonicParsing="false" onAction="#abrirGestionPerfil" text="Gestionar el Perfil" />
      <Button fx:id="btnGestionCompras" layoutX="129.0" layoutY="244.0" mnemonicParsing="false" onAction="#abrirGestionCompraUsuario" text="Gestionar las Compras" />
      <Button fx:id="btnGestionPerfil11" layoutX="326.0" layoutY="244.0" mnemonicParsing="false" onAction="#abrirHistorialCompra" text="Historial de Compras" />
    </children>

</AnchorPane>
