<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="co.edu.uniquindio.poo.proyectofinalctrlexito.viewController.GestionPerfilViewController"
            prefHeight="400.0" prefWidth="600.0">

    <Label layoutX="180" layoutY="20" style="-fx-font-size: 28px;" text="Gestión del Usuario" />

    <TableView fx:id="tablaUsuario" layoutX="25" layoutY="70" prefHeight="250" prefWidth="550.0">
        <columns>
            <TableColumn fx:id="colNombreCompleto" prefWidth="200" text="NombreCompleto" />
            <TableColumn fx:id="colCorreo" prefWidth="157.39996337890625" text="Correo" />
            <TableColumn fx:id="colTelefono" prefWidth="199.20004272460938" text="Telefono" />
        </columns>
    </TableView>
    <TextField fx:id="txtNombreCompleto" layoutX="50.0" layoutY="340.0" prefWidth="150" promptText="Nombre Completo" />
    <TextField fx:id="txtCorreo" layoutX="248.0" layoutY="340.0" prefWidth="150" promptText="Correo" />
    <TextField fx:id="txtTelefono" layoutX="422.0" layoutY="340.0" prefWidth="150" promptText="Telefono" />


    <Button fx:id="btnCrear" layoutX="25" layoutY="380" prefWidth="80" text="Crear" />
    <Button fx:id="btnEliminar" layoutX="110" layoutY="380" prefWidth="80" text="Eliminar" />
    <Button fx:id="btnVolver" layoutX="524.0" layoutY="380.0" mnemonicParsing="false" onAction="#volver" text="Volver" />


</AnchorPane>
